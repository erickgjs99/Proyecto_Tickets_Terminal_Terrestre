# ============================================================
# Terminal Terrestre — Variables de Entorno
# Para desarrollo: copiar como .env
# Para producción: copiar como .env.production
# ============================================================

# ----------------------------------------------------------
# Django
# Generar SECRET_KEY con:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
# ----------------------------------------------------------
SECRET_KEY=tu-clave-secreta-muy-larga-y-aleatoria-aqui
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ----------------------------------------------------------
# Base de datos PostgreSQL
# ----------------------------------------------------------
DB_NAME=terminal_terrestre
DB_USER=postgres
DB_PASSWORD=tu_password_postgres
DB_HOST=localhost
DB_PORT=5432

# ----------------------------------------------------------
# Timezone
# ----------------------------------------------------------
TIME_ZONE=America/Guayaquil

# ----------------------------------------------------------
# CORS (solo si se consume desde otro origen)
# ----------------------------------------------------------
CORS_ALLOWED_ORIGINS=http://localhost:8000
